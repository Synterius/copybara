{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Copybara",
  "version": "../package.json",
  "identifier": "com.cyv.copybara",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Copybara",
        "width": 800,
        "height": 600,
        "visible": false,
        "backgroundColor": "#1e1e1e"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYzQ0IzMjQ1N0I4OUE2RjcKUldUM3BvbDdSVExMODBWZVoxd2lKSHJYQ0luUys0dlljUUZaV1RacjhqRlVBYVNFeUZIelVid3IK",
      "endpoints": [
        "https://raw.githubusercontent.com/Synterius/copybara-releases/main/latest.json"
      ]
    }
  }
}